<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DUDI Master - Professional Internship Management</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script crossorigin src="https://unpkg.com/react@18.2.0/umd/react.development.js"></script>
    <script crossorigin src="https://unpkg.com/react-dom@18.2.0/umd/react-dom.development.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Plus Jakarta Sans', ui-sans-serif, system-ui, sans-serif; background-color: #f0f4f8; }
        .bg-navy { background-color: #003056; }
        .bg-navy-dark { background-color: #001f38; }
        .text-navy { color: #003056; }
        .border-navy { border-color: #003056; }
        .hover\:bg-navy-dark:hover { background-color: #001f38; }
        .hover\:text-navy:hover { color: #003056; }
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: #f1f5f9; border-radius: 10px; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .animate-fadeIn { animation: fadeIn 0.3s ease-out forwards; }
    </style>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useMemo } = React;

        // Icons as SVG components
        const Building2 = ({ size = 20 }) => React.createElement('svg', { width: size, height: size, viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', strokeWidth: 2, strokeLinecap: 'round', strokeLinejoin: 'round' },
            React.createElement('rect', { x: 4, y: 2, width: 16, height: 20, rx: 2, ry: 2 }),
            React.createElement('path', { d: 'M9 22v-4h6v4' })
        );
        const Search = ({ size = 16 }) => React.createElement('svg', { width: size, height: size, viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', strokeWidth: 2, strokeLinecap: 'round', strokeLinejoin: 'round' },
            React.createElement('circle', { cx: 11, cy: 11, r: 8 }),
            React.createElement('line', { x1: 21, y1: 21, x2: 16.65, y2: 16.65 })
        );
        const Plus = ({ size = 18 }) => React.createElement('svg', { width: size, height: size, viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', strokeWidth: 2, strokeLinecap: 'round', strokeLinejoin: 'round' },
            React.createElement('line', { x1: 12, y1: 5, x2: 12, y2: 19 }),
            React.createElement('line', { x1: 5, y1: 12, x2: 19, y2: 12 })
        );
        const Filter = ({ size = 16 }) => React.createElement('svg', { width: size, height: size, viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', strokeWidth: 2, strokeLinecap: 'round', strokeLinejoin: 'round' },
            React.createElement('polygon', { points: '22 3 2 3 10 13 10 21 14 18 14 13 22 3' })
        );
        const Edit3 = ({ size = 18 }) => React.createElement('svg', { width: size, height: size, viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', strokeWidth: 2, strokeLinecap: 'round', strokeLinejoin: 'round' },
            React.createElement('path', { d: 'M17 3l4 4-7 7H10v-4l7-7z' }),
            React.createElement('path', { d: 'M4 20h16' })
        );
        const Trash2 = ({ size = 18 }) => React.createElement('svg', { width: size, height: size, viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', strokeWidth: 2, strokeLinecap: 'round', strokeLinejoin: 'round' },
            React.createElement('path', { d: 'M3 6h18' }),
            React.createElement('path', { d: 'M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6' }),
            React.createElement('path', { d: 'M8 4V2h8v2' })
        );
        const ExternalLink = ({ size = 12 }) => React.createElement('svg', { width: size, height: size, viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', strokeWidth: 2, strokeLinecap: 'round', strokeLinejoin: 'round' },
            React.createElement('path', { d: 'M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6' }),
            React.createElement('polyline', { points: '15 3 21 3 21 9' }),
            React.createElement('line', { x1: 10, y1: 14, x2: 21, y2: 3 })
        );
        const Database = ({ size = 14 }) => React.createElement('svg', { width: size, height: size, viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', strokeWidth: 2, strokeLinecap: 'round', strokeLinejoin: 'round' },
            React.createElement('ellipse', { cx: 12, cy: 5, rx: 9, ry: 3 }),
            React.createElement('path', { d: 'M21 12c0 1.66-4 3-9 3s-9-1.34-9-3' }),
            React.createElement('path', { d: 'M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5' })
        );
        const Clock = ({ size = 14 }) => React.createElement('svg', { width: size, height: size, viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', strokeWidth: 2, strokeLinecap: 'round', strokeLinejoin: 'round' },
            React.createElement('circle', { cx: 12, cy: 12, r: 10 }),
            React.createElement('polyline', { points: '12 6 12 12 16 14' })
        );

        const MOCK_DUDI = [
            { id: 1, nama_dudi: "PT. Teknologi Bangsa Software", alamat: "Jl. Merdeka No. 45, Jakarta Pusat", jam_berangkat: "08:00", jam_pulang: "17:00", bidang_industri: "Software Development", jumlah_pegawai: "150+", website: "www.tekbangsa.com", telepon: "021-5556677", email: "hrd@tekbangsa.com", kuota: 5, penanggung_jawab: "Siska Amelia", terdaftar: 2 },
            { id: 2, nama_dudi: "Digital Creative Hub", alamat: "Gedung Cyber 2, Lt. 10, Jakarta Selatan", jam_berangkat: "09:00", jam_pulang: "18:00", bidang_industri: "Digital Marketing", jumlah_pegawai: "45", website: "www.creativehub.id", telepon: "021-8889900", email: "contact@creativehub.id", kuota: 3, penanggung_jawab: "Budi Santoso", terdaftar: 3 },
            { id: 3, nama_dudi: "Indo Cloud Solutions", alamat: "Kawasan Industri Pulo Gadung, Jakarta Timur", jam_berangkat: "08:30", jam_pulang: "17:30", bidang_industri: "Cloud Computing", jumlah_pegawai: "300", website: "www.indocloud.net", telepon: "021-1112233", email: "jobs@indocloud.net", kuota: 8, penanggung_jawab: "Agus Pratama", terdaftar: 1 }
        ];

        const App = () => {
            const [search, setSearch] = useState("");
            const [bidangFilter, setBidangFilter] = useState("Semua Bidang");

            const filteredData = useMemo(() => {
                return MOCK_DUDI.filter(dudi => {
                    const matchesSearch = dudi.nama_dudi.toLowerCase().includes(search.toLowerCase()) || dudi.bidang_industri.toLowerCase().includes(search.toLowerCase());
                    const matchesBidang = bidangFilter === "Semua Bidang" || dudi.bidang_industri === bidangFilter;
                    return matchesSearch && matchesBidang;
                });
            }, [search, bidangFilter]);

            const uniqueBidang = Array.from(new Set(MOCK_DUDI.map(d => d.bidang_industri))).sort();
            const totalDudi = MOCK_DUDI.length;
            const totalKuota = MOCK_DUDI.reduce((acc, curr) => acc + curr.kuota, 0);

            const today = new Date();
            const formattedDate = today.toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' });
            const formattedTime = today.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });

            return React.createElement('div', { className: "min-h-screen bg-[#f0f4f8]" },
                // Header
                React.createElement('header', { className: "bg-[#003056] text-white px-6 lg:px-8 py-6 shadow-lg relative overflow-hidden" },
                    React.createElement('div', { className: "container mx-auto flex flex-col md:flex-row justify-between items-center gap-6 relative z-10" },
                        React.createElement('div', null,
                            React.createElement('h1', { className: "text-2xl lg:text-3xl font-bold tracking-tight mb-1" }, "Data Perusahaan (DUDI)"),
                            React.createElement('p', { className: "text-slate-300 text-sm opacity-80" }, "Portal Administrasi Program Praktik Kerja Lapangan Terpadu")
                        ),
                        React.createElement('div', { className: "flex gap-6" },
                            React.createElement('div', { className: "text-center border-r border-white/20 pr-6" },
                                React.createElement('span', { className: "block text-2xl lg:text-3xl font-bold text-white" }, totalDudi),
                                React.createElement('span', { className: "text-[9px] lg:text-[10px] uppercase tracking-[0.2em] text-slate-300 font-bold" }, "Total DUDI")
                            ),
                            React.createElement('div', { className: "text-center" },
                                React.createElement('span', { className: "block text-2xl lg:text-3xl font-bold text-white" }, totalKuota),
                                React.createElement('span', { className: "text-[9px] lg:text-[10px] uppercase tracking-[0.2em] text-slate-300 font-bold" }, "Total Kuota")
                            )
                        )
                    ),
                    React.createElement('div', { className: "absolute -top-12 -right-12 w-48 h-48 bg-white/5 rounded-full blur-2xl" })
                ),

                // Main Content
                React.createElement('main', { className: "container mx-auto px-4 py-6 lg:py-8" },
                    React.createElement('div', { className: "bg-white rounded-xl lg:rounded-2xl shadow-xl overflow-hidden border border-slate-200" },
                        // Toolbar
                        React.createElement('div', { className: "bg-slate-50 p-4 lg:p-6 border-b border-slate-200 flex flex-col md:flex-row justify-between items-center gap-4" },
                            React.createElement('div', { className: "flex flex-col sm:flex-row gap-4 w-full md:w-auto" },
                                React.createElement('div', { className: "relative flex-1 sm:flex-initial" },
                                    React.createElement('div', { className: "absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none" },
                                        React.createElement(Search, { size: 16 })
                                    ),
                                    React.createElement('input', {
                                        type: "text",
                                        placeholder: "Cari Nama atau Bidang Industri...",
                                        className: "pl-10 pr-4 py-2 border border-slate-300 rounded-lg text-sm w-full sm:w-80 focus:outline-none focus:ring-2 focus:ring-[#003056]/20 focus:border-[#003056] transition-all bg-white font-medium",
                                        value: search,
                                        onChange: (e) => setSearch(e.target.value)
                                    })
                                ),
                                React.createElement('div', { className: "relative flex-1 sm:flex-initial" },
                                    React.createElement('div', { className: "absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none" },
                                        React.createElement(Filter, { size: 16 })
                                    ),
                                    React.createElement('select', {
                                        className: "bg-white border border-slate-300 rounded-lg text-sm pl-10 pr-8 py-2 outline-none focus:ring-2 focus:ring-[#003056]/20 focus:border-[#003056] transition-all appearance-none cursor-pointer w-full sm:w-auto font-medium",
                                        value: bidangFilter,
                                        onChange: (e) => setBidangFilter(e.target.value)
                                    },
                                        React.createElement('option', null, "Semua Bidang"),
                                        uniqueBidang.map(b => React.createElement('option', { key: b, value: b }, b))
                                    )
                                )
                            ),
                            React.createElement('button', { className: "bg-[#003056] hover:bg-[#001f38] text-white px-6 py-2 rounded-lg text-sm font-bold transition shadow-md flex items-center gap-2 w-full md:w-auto justify-center" },
                                React.createElement(Plus, { size: 18 }), " Tambah DUDI Baru"
                            )
                        ),

                        // Table - Responsive scroll
                        React.createElement('div', { className: "overflow-x-auto" },
                            React.createElement('table', { className: "w-full text-left min-w-[1200px]" },
                                React.createElement('thead', null,
                                    React.createElement('tr', { className: "bg-[#003056] text-white text-[10px] lg:text-[11px] uppercase font-bold tracking-wider border-b border-white/10" },
                                        React.createElement('th', { className: "px-4 lg:px-6 py-4 text-center w-16" }, "No"),
                                        React.createElement('th', { className: "px-4 lg:px-6 py-4" }, "Nama DUDI"),
                                        React.createElement('th', { className: "px-4 lg:px-6 py-4" }, "Alamat"),
                                        React.createElement('th', { className: "px-4 lg:px-6 py-4 text-center" }, "Jam Berangkat"),
                                        React.createElement('th', { className: "px-4 lg:px-6 py-4 text-center" }, "Jam Pulang"),
                                        React.createElement('th', { className: "px-4 lg:px-6 py-4" }, "Bidang Industri"),
                                        React.createElement('th', { className: "px-4 lg:px-6 py-4 text-center" }, "Jumlah Pegawai"),
                                        React.createElement('th', { className: "px-4 lg:px-6 py-4" }, "Website"),
                                        React.createElement('th', { className: "px-4 lg:px-6 py-4" }, "No. Telp"),
                                        React.createElement('th', { className: "px-4 lg:px-6 py-4" }, "Email"),
                                        React.createElement('th', { className: "px-4 lg:px-6 py-4 text-center" }, "Kuota"),
                                        React.createElement('th', { className: "px-4 lg:px-6 py-4" }, "Penanggung Jawab"),
                                        React.createElement('th', { className: "px-4 lg:px-6 py-4 text-right sticky right-0 bg-[#003056]" }, "Aksi")
                                    )
                                ),
                                React.createElement('tbody', { className: "divide-y divide-slate-100" },
                                    filteredData.map((dudi, idx) => 
                                        React.createElement('tr', {
                                            key: dudi.id,
                                            className: "hover:bg-slate-50/50 transition-colors group",
                                            style: { animation: `fadeIn 0.3s ease-out ${idx * 0.05}s both` }
                                        },
                                            React.createElement('td', { className: "px-4 lg:px-6 py-4 text-center text-slate-400 font-mono text-xs" },
                                                String(idx + 1).padStart(2, '0')
                                            ),
                                            React.createElement('td', { className: "px-4 lg:px-6 py-4" },
                                                React.createElement('div', { className: "font-bold text-[#003056] text-sm" }, dudi.nama_dudi)
                                            ),
                                            React.createElement('td', { className: "px-4 lg:px-6 py-4" },
                                                React.createElement('div', { className: "text-slate-500 font-semibold text-xs leading-relaxed max-w-xs" }, dudi.alamat)
                                            ),
                                            React.createElement('td', { className: "px-4 lg:px-6 py-4 text-center" },
                                                React.createElement('span', { className: "bg-[#003056]/5 px-2 py-1 rounded text-[#003056] font-bold text-xs" }, dudi.jam_berangkat)
                                            ),
                                            React.createElement('td', { className: "px-4 lg:px-6 py-4 text-center" },
                                                React.createElement('span', { className: "bg-slate-100 px-2 py-1 rounded text-slate-500 font-bold text-xs" }, dudi.jam_pulang)
                                            ),
                                            // Bagian Bidang Industri - tanpa badge, hanya teks biasa
                                            React.createElement('td', { className: "px-4 lg:px-6 py-4 text-slate-700 font-semibold text-xs" }, dudi.bidang_industri),
                                            React.createElement('td', { className: "px-4 lg:px-6 py-4 text-center font-bold text-slate-500 italic text-xs" }, dudi.jumlah_pegawai),
                                            React.createElement('td', { className: "px-4 lg:px-6 py-4" },
                                                React.createElement('a', { href: `https://${dudi.website}`, target: "_blank", rel: "noreferrer", className: "text-blue-500 font-bold italic text-xs hover:underline flex items-center gap-1" },
                                                    dudi.website, React.createElement(ExternalLink, { size: 12 })
                                                )
                                            ),
                                            React.createElement('td', { className: "px-4 lg:px-6 py-4 font-semibold text-slate-600 text-xs" }, dudi.telepon),
                                            React.createElement('td', { className: "px-4 lg:px-6 py-4 font-semibold text-slate-600 text-xs" }, dudi.email),
                                            React.createElement('td', { className: "px-4 lg:px-6 py-4 text-center" },
                                                React.createElement('div', { className: "flex flex-col items-center" },
                                                    React.createElement('span', { className: "text-base lg:text-lg font-black text-[#003056] leading-none" }, dudi.kuota),
                                                    React.createElement('span', { className: "text-[8px] font-bold text-slate-400" }, `(${dudi.terdaftar} Terdaftar)`)
                                                )
                                            ),
                                            React.createElement('td', { className: "px-4 lg:px-6 py-4" },
                                                React.createElement('div', { className: "font-bold text-slate-700 text-xs" }, dudi.penanggung_jawab)
                                            ),
                                            React.createElement('td', { className: "px-4 lg:px-6 py-4 text-right sticky right-0 bg-white/95 backdrop-blur-sm group-hover:bg-transparent" },
                                                React.createElement('div', { className: "flex justify-end gap-1" },
                                                    React.createElement('button', { className: "text-[#003056] hover:text-[#003056]/70 p-1.5 hover:bg-[#003056]/5 rounded-lg transition-all" },
                                                        React.createElement(Edit3, { size: 16 })
                                                    ),
                                                    React.createElement('button', { className: "text-red-500 hover:text-red-700 p-1.5 hover:bg-red-50 rounded-lg transition-all" },
                                                        React.createElement(Trash2, { size: 16 })
                                                    )
                                                )
                                            )
                                        )
                                    ),
                                    filteredData.length === 0 && React.createElement('tr', null,
                                        React.createElement('td', { colSpan: 13, className: "px-6 py-16 text-center text-slate-300" },
                                            React.createElement('div', { className: "flex flex-col items-center gap-3" },
                                                React.createElement(Search, { size: 48, className: "opacity-10" }),
                                                React.createElement('p', { className: "font-bold text-xs uppercase tracking-widest" }, "Data Tidak Ditemukan")
                                            )
                                        )
                                    )
                                )
                            )
                        ),

                        // Footer
                        React.createElement('div', { className: "bg-[#003056] text-white/70 px-4 lg:px-8 py-5 flex flex-col md:flex-row justify-between items-center gap-4 text-[9px] lg:text-[10px] uppercase font-bold tracking-[0.2em]" },
                            React.createElement('div', { className: "flex items-center gap-3" },
                                React.createElement(Database, { size: 14 }),
                                React.createElement('span', null, "Total data tersimpan: ", React.createElement('span', { className: "text-white font-black" }, totalDudi), " perusahaan")
                            ),
                            React.createElement('div', { className: "flex items-center gap-3" },
                                React.createElement(Clock, { size: 14 }),
                                React.createElement('span', null, "Terakhir diperbarui: ", React.createElement('span', { className: "text-white font-medium" }, `${formattedDate}, ${formattedTime}`))
                            )
                        )
                    ),
                    React.createElement('div', { className: "mt-8 text-center pb-8" },
                        React.createElement('p', { className: "text-slate-400 text-[8px] lg:text-[9px] uppercase tracking-[0.3em] font-black" }, "Sistem Informasi PKL Terpadu © 2026 • Professional Edition")
                    )
                )
            );
        };

        // Add keyframe style
        const style = document.createElement('style');
        style.textContent = `@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }`;
        document.head.appendChild(style);

        ReactDOM.createRoot(document.getElementById('root')).render(React.createElement(App, null));
    </script>
</body>
</html>