<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Elite Student Registry - Pendaftaran Siswa Baru</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #f0f4f8 0%, #e8edf2 100%);
            min-height: 100vh;
        }
        
        .font-serif {
            font-family: 'Georgia', serif;
            font-style: italic;
        }
        
        .btn-primary {
            background: #003056;
            color: white;
            transition: all 0.3s ease;
        }
        
        .btn-primary:hover {
            background: #002845;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(0, 48, 86, 0.2);
        }
        
        .card-shadow {
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
        }
        
        .radio-card {
            transition: all 0.2s ease;
        }
        
        .radio-card:hover {
            border-color: #003056;
            background: #f8fafc;
        }
        
        .radio-selected {
            background: #003056 !important;
            border-color: #003056 !important;
            color: white !important;
            box-shadow: 0 4px 12px rgba(0, 48, 86, 0.25);
        }
        
        .upload-zone {
            transition: all 0.2s ease;
        }
        
        .upload-zone:hover {
            border-color: #003056 !important;
            background: #f8fafc !important;
        }
        
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        .animate-fade-in-up {
            animation: fadeInUp 0.6s ease-out forwards;
        }
        
        .delay-100 {
            animation-delay: 0.1s;
            opacity: 0;
        }
        
        .delay-200 {
            animation-delay: 0.2s;
            opacity: 0;
        }
        
        .delay-300 {
            animation-delay: 0.3s;
            opacity: 0;
        }
    </style>
</head>
<body>

<div id="root"></div>

<script>
    // Data state
    let formData = {
        nis: '',
        nama: '',
        kelas: '',
        foto: null
    };
    let previewUrl = null;
    let isSubmitting = false;
    let isSuccess = false;

    // Icons as HTML
    const icons = {
        hash: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="4" y1="9" x2="20" y2="9"/><line x1="4" y1="15" x2="20" y2="15"/><line x1="10" y1="3" x2="8" y2="21"/><line x1="16" y1="3" x2="14" y2="21"/></svg>`,
        user: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`,
        upload: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>`,
        check: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#003056" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="9 12 11 14 15 10"/></svg>`,
        arrow: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>`,
        school: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>`
    };

    function updatePreview(file) {
        if (file) {
            const reader = new FileReader();
            reader.onload = function(e) {
                previewUrl = e.target.result;
                render();
            };
            reader.readAsDataURL(file);
        }
    }

    function handleFileChange(e) {
        const file = e.target.files[0];
        if (file) {
            formData.foto = file;
            updatePreview(file);
        }
    }

    function handleSubmit(e) {
        e.preventDefault();
        if (!formData.nis || !formData.nama || !formData.kelas) {
            alert('Harap lengkapi semua field yang wajib diisi!');
            return;
        }
        
        isSubmitting = true;
        render();
        
        setTimeout(() => {
            isSubmitting = false;
            isSuccess = true;
            render();
        }, 1500);
    }

    function resetForm() {
        formData = { nis: '', nama: '', kelas: '', foto: null };
        previewUrl = null;
        isSubmitting = false;
        isSuccess = false;
        render();
    }

    function setKelas(kelas) {
        formData.kelas = kelas;
        render();
    }

    function updateNis(value) {
        formData.nis = value;
        render();
    }

    function updateNama(value) {
        formData.nama = value;
        render();
    }

    function renderSuccess() {
        return `
            <div class="min-h-screen flex items-center justify-center p-6">
                <div class="max-w-md w-full bg-white rounded-3xl shadow-2xl overflow-hidden animate-fade-in-up">
                    <div class="h-1.5 bg-[#003056]"></div>
                    <div class="p-12 text-center">
                        <div class="w-20 h-20 bg-[#003056]/5 rounded-full flex items-center justify-center mx-auto mb-6">
                            ${icons.check}
                        </div>
                        <h2 class="text-3xl font-light text-[#003056] mb-3">Pendaftaran <span class="font-serif">Berhasil</span></h2>
                        <p class="text-slate-500 text-sm mb-8">Data siswa <strong class="text-[#003056]">${formData.nama}</strong> telah berhasil disimpan ke dalam sistem akademik terpadu.</p>
                        <button onclick="resetForm()" class="w-full bg-[#003056] text-white py-3.5 rounded-xl font-semibold text-sm hover:bg-[#002845] transition-all flex items-center justify-center gap-2">
                            Daftarkan Siswa Lain ${icons.arrow}
                        </button>
                    </div>
                </div>
            </div>
        `;
    }

    function renderForm() {
        const isSelected = (kelas) => formData.kelas === kelas ? 'radio-selected' : '';
        
        return `
            <div class="min-h-screen flex flex-col items-center justify-center p-6 lg:p-10">
                <!-- Background Decor -->
                <div class="fixed inset-0 pointer-events-none overflow-hidden">
                    <div class="absolute top-[-10%] right-[-5%] w-[40%] h-[40%] bg-[#003056]/5 rounded-full blur-[120px]"></div>
                    <div class="absolute bottom-[-10%] left-[-5%] w-[30%] h-[30%] bg-blue-100/30 rounded-full blur-[100px]"></div>
                </div>
                
                <div class="w-full max-w-4xl relative z-10">
                    <!-- Header -->
                    <div class="text-center mb-10 animate-fade-in-up">
                        <div class="inline-block mb-4 px-4 py-1.5 rounded-full bg-[#003056]/5 border border-[#003056]/10">
                            <span class="text-[10px] font-black text-[#003056] uppercase tracking-[0.2em]">Sistem Akademik Terpadu</span>
                        </div>
                        <h1 class="text-4xl md:text-5xl font-light text-[#003056] tracking-tight mb-3">
                            Pendaftaran <span class="font-serif text-[1.1em]">Siswa Baru</span>
                        </h1>
                        <p class="text-slate-500 text-sm max-w-lg mx-auto">
                            Silakan lengkapi informasi biodata siswa untuk registrasi angkatan akademik 
                            <span class="font-semibold text-[#003056]/80">2024/2025</span>
                        </p>
                    </div>

                    <!-- Form Card -->
                    <div class="bg-white rounded-3xl shadow-2xl border border-slate-100 overflow-hidden animate-fade-in-up delay-100">
                        <div class="h-1.5 bg-[#003056]"></div>
                        
                        <div class="p-8 md:p-12">
                            <form onsubmit="handleSubmit(event)">
                                <div class="grid md:grid-cols-2 gap-8 lg:gap-12">
                                    <!-- Left Column -->
                                    <div class="space-y-6">
                                        <!-- NIS Field -->
                                        <div>
                                            <label class="text-[11px] font-black uppercase tracking-[0.05em] text-[#003056] block mb-2">Nomor Induk Siswa (NIS) *</label>
                                            <div class="relative">
                                                <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-300">${icons.hash}</span>
                                                <input type="text" 
                                                       required
                                                       placeholder="Contoh: 212210045"
                                                       class="w-full pl-11 pr-4 py-3 bg-white border border-slate-200 rounded-xl text-sm text-slate-800 focus:outline-none focus:border-[#003056] focus:ring-3 focus:ring-[#003056]/10 transition-all"
                                                       value="${formData.nis}"
                                                       oninput="updateNis(this.value)">
                                            </div>
                                        </div>
                                        
                                        <!-- Nama Field -->
                                        <div>
                                            <label class="text-[11px] font-black uppercase tracking-[0.05em] text-[#003056] block mb-2">Nama Lengkap Siswa *</label>
                                            <div class="relative">
                                                <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-300">${icons.user}</span>
                                                <input type="text" 
                                                       required
                                                       placeholder="Masukkan nama sesuai ijazah"
                                                       class="w-full pl-11 pr-4 py-3 bg-white border border-slate-200 rounded-xl text-sm text-slate-800 focus:outline-none focus:border-[#003056] focus:ring-3 focus:ring-[#003056]/10 transition-all"
                                                       value="${formData.nama}"
                                                       oninput="updateNama(this.value)">
                                            </div>
                                        </div>
                                        
                                        <!-- Kelas Radio -->
                                        <div>
                                            <label class="text-[11px] font-black uppercase tracking-[0.05em] text-[#003056] block mb-2">Pilih Penempatan Kelas *</label>
                                            <div class="flex gap-3">
                                                <div onclick="setKelas('XIII SIJA 1')" 
                                                     class="flex-1 cursor-pointer border border-slate-200 rounded-xl py-3 text-center font-semibold text-sm transition-all radio-card ${isSelected('XIII SIJA 1')}">
                                                    XIII SIJA 1
                                                </div>
                                                <div onclick="setKelas('XIII SIJA 2')" 
                                                     class="flex-1 cursor-pointer border border-slate-200 rounded-xl py-3 text-center font-semibold text-sm transition-all radio-card ${isSelected('XIII SIJA 2')}">
                                                    XIII SIJA 2
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Right Column -->
                                    <div class="space-y-6">
                                        <!-- Upload Foto -->
                                        <div>
                                            <label class="text-[11px] font-black uppercase tracking-[0.05em] text-[#003056] block mb-2">Pas Foto Siswa (Opsional)</label>
                                            <div class="upload-zone relative border-2 border-dashed rounded-xl p-8 text-center cursor-pointer transition-all ${previewUrl ? 'border-[#003056]/40 bg-[#003056]/5' : 'border-slate-200 hover:border-[#003056]/40 hover:bg-slate-50'}">
                                                <input type="file" accept="image/*" class="absolute inset-0 opacity-0 cursor-pointer" onchange="handleFileChange(event)">
                                                ${previewUrl ? `
                                                    <div class="text-center">
                                                        <img src="${previewUrl}" class="w-24 h-24 object-cover rounded-xl mx-auto shadow-md mb-3 border-2 border-white">
                                                        <p class="text-xs font-bold text-[#003056]">Foto terpilih</p>
                                                    </div>
                                                ` : `
                                                    <div class="text-center">
                                                        <div class="w-14 h-14 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-3 transition-colors">${icons.upload}</div>
                                                        <p class="text-sm font-semibold text-slate-600 mb-1">Unggah berkas</p>
                                                        <p class="text-[10px] text-slate-400 uppercase tracking-wider font-bold">PNG, JPG hingga 2MB</p>
                                                    </div>
                                                `}
                                            </div>
                                        </div>
                                        
                                        <!-- Buttons -->
                                        <div class="pt-4 flex items-center justify-end gap-3">
                                            <button type="button" onclick="resetForm()" class="px-6 py-3 text-slate-500 font-semibold text-sm rounded-xl hover:bg-slate-100 transition-all">
                                                Reset
                                            </button>
                                            <button type="submit" 
                                                    ${isSubmitting ? 'disabled' : ''}
                                                    class="px-8 py-3 bg-[#003056] text-white font-bold text-sm rounded-xl shadow-lg shadow-[#003056]/15 hover:shadow-xl transition-all flex items-center gap-2 min-w-[180px] justify-center">
                                                ${isSubmitting ? 'Memproses...' : 'Simpan Data Siswa'}
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- Footer -->
                    <div class="mt-10 flex flex-wrap justify-center items-center gap-6 text-[9px] text-slate-400 uppercase tracking-[0.3em] font-black animate-fade-in-up delay-200">
                        <div class="flex items-center">
                            <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 mr-2 animate-pulse"></span>
                            Cloud Registry Active
                        </div>
                        <span class="opacity-30">•</span>
                        <div>Dokumentasi Digital</div>
                        <span class="opacity-30">•</span>
                        <div>Secure Access v4.2</div>
                    </div>
                </div>
            </div>
        `;
    }

    function render() {
        const root = document.getElementById('root');
        if (root) {
            if (isSuccess) {
                root.innerHTML = renderSuccess();
            } else {
                root.innerHTML = renderForm();
            }
        }
    }

    // Initial render
    render();
</script>

<style>
    @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
    }
    .animate-pulse {
        animation: pulse 2s infinite;
    }
    .radio-card {
        transition: all 0.2s ease;
    }
    .radio-card:hover:not(.radio-selected) {
        border-color: #003056;
        background-color: #f8fafc;
    }
    .radio-selected {
        background: #003056 !important;
        border-color: #003056 !important;
        color: white !important;
        box-shadow: 0 4px 12px rgba(0, 48, 86, 0.25);
    }
    .upload-zone {
        transition: all 0.2s ease;
    }
</style>

</body>
</html>