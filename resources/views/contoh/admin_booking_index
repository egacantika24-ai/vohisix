        .border-primary { border-color: #003056; }
        .ring-primary { ring-color: #003056; }
        .from-primary { --tw-gradient-from: #003056; }
        .to-primary { --tw-gradient-to: #003056; }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #F1F5F9; border-radius: 10px; }
        ::-webkit-scrollbar-thumb { background: #003056; border-radius: 10px; }
        @keyframes scaleIn { from { opacity: 0; scale: 0.95; } to { opacity: 1; scale: 1; } }
    </style>
</head>
<body>
