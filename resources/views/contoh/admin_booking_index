        const Clock = ({ size = 16 }) => React.createElement('svg', { width: size, height: size, viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', strokeWidth: 2, strokeLinecap: 'round', strokeLinejoin: 'round' },
            React.createElement('circle', { cx: 12, cy: 12, r: 10 }),
            React.createElement('polyline', { points: '12 6 12 12 16 14' })
        );
        const Building2 = ({ size = 20 }) => React.createElement('svg', { width: size, height: size, viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', strokeWidth: 2, strokeLinecap: 'round', strokeLinejoin: 'round' },
            React.createElement('rect', { x: 4, y: 2, width: 16, height: 20, rx: 2, ry: 2 }),
            React.createElement('path', { d: 'M9 22v-4h6v4' })
        );
        const Users = ({ size = 20 }) => React.createElement('svg', { width: size, height: size, viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', strokeWidth: 2, strokeLinecap: 'round', strokeLinejoin: 'round' },
            React.createElement('path', { d: 'M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2' }),
            React.createElement('circle', { cx: 9, cy: 7, r: 4 }),
            React.createElement('path', { d: 'M23 21v-2a4 4 0 0 0-3-3.87' }),
            React.createElement('path', { d: 'M16 3.13a4 4 0 0 1 0 7.75' })
        );
        const FileText = ({ size = 20 }) => React.createElement('svg', { width: size, height: size, viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', strokeWidth: 2, strokeLinecap: 'round', strokeLinejoin: 'round' },
            React.createElement('path', { d: 'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z' }),
            React.createElement('polyline', { points: '14 2 14 8 20 8' })
        );
        const CheckCircle = ({ size = 18 }) => React.createElement('svg', { width: size, height: size, viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', strokeWidth: 2, strokeLinecap: 'round', strokeLinejoin: 'round' },
            React.createElement('path', { d: 'M22 11.08V12a10 10 0 1 1-5.93-9.14' }),
            React.createElement('polyline', { points: '22 4 12 14.01 9 11.01' })
        );
        const XCircle = ({ size = 18 }) => React.createElement('svg', { width: size, height: size, viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', strokeWidth: 2, strokeLinecap: 'round', strokeLinejoin: 'round' },
            React.createElement('circle', { cx: 12, cy: 12, r: 10 }),
            React.createElement('line', { x1: 15, y1: 9, x2: 9, y2: 15 }),
            React.createElement('line', { x1: 9, y1: 9, x2: 15, y2: 15 })
        );
        const ClockIcon = ({ size = 18 }) => React.createElement('svg', { width: size, height: size, viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', strokeWidth: 2, strokeLinecap: 'round', strokeLinejoin: 'round' },
            React.createElement('circle', { cx: 12, cy: 12, r: 10 }),
            React.createElement('polyline', { points: '12 6 12 12 16 14' })
        );

        // Mock Data Booking
        const MOCK_BOOKINGS = [
            { id: 1, nama_siswa: "Ahmad Fauzi", nis: "212210001", nama_dudi: "PT Teknologi Digital Indonesia", status: "Diterima", tanggal: "15 Apr 2026" },
            { id: 2, nama_siswa: "Siti Nurhaliza", nis: "212210002", nama_dudi: "Bank Central Nasional", status: "Ditolak", tanggal: "18 Apr 2026" },
            { id: 3, nama_siswa: "Budi Santoso", nis: "212210003", nama_dudi: "Startup Kreatif Nusantara", status: "Direview", tanggal: "20 Apr 2026" },
            { id: 4, nama_siswa: "Diana Putri", nis: "212210004", nama_dudi: "Global Logistik Perkasa", status: "Direview", tanggal: "21 Apr 2026" },
            { id: 5, nama_siswa: "Eko Prasetyo", nis: "212210005", nama_dudi: "PT Solusi Digital", status: "Diterima", tanggal: "22 Apr 2026" },
            { id: 6, nama_siswa: "Rina Wati", nis: "212210006", nama_dudi: "CV Kreatif Mandiri", status: "Ditolak", tanggal: "23 Apr 2026" }
        ];

        const App = () => {
            const [search, setSearch] = useState("");
            const [statusFilter, setStatusFilter] = useState("Semua Status");
            const [sortBy, setSortBy] = useState("newest");

            const filteredData = useMemo(() => {
                let data = MOCK_BOOKINGS.filter(booking => {
                    const matchesSearch = booking.nama_siswa.toLowerCase().includes(search.toLowerCase()) || 
                                         booking.nis.includes(search);
                    const matchesStatus = statusFilter === "Semua Status" || booking.status === statusFilter;
                    return matchesSearch && matchesStatus;
                });

                data = [...data].sort((a, b) => {
                    if (sortBy === "newest") {
                        const dateA = new Date(a.tanggal);
                        const dateB = new Date(b.tanggal);
                        return dateB - dateA;
                    }
                    if (sortBy === "oldest") {
                        const dateA = new Date(a.tanggal);
                        const dateB = new Date(b.tanggal);
                        return dateA - dateB;
                    }
                    if (sortBy === "siswa_asc") return a.nama_siswa.localeCompare(b.nama_siswa);
                    if (sortBy === "siswa_desc") return b.nama_siswa.localeCompare(a.nama_siswa);
                    return 0;
                });

                return data;
            }, [search, statusFilter, sortBy]);

            const totalBooking = MOCK_BOOKINGS.length;
            const bookingDireview = MOCK_BOOKINGS.filter(b => b.status === "Direview").length;
            const bookingDiterima = MOCK_BOOKINGS.filter(b => b.status === "Diterima").length;
            const bookingDitolak = MOCK_BOOKINGS.filter(b => b.status === "Ditolak").length;

            const today = new Date();
            const formattedDate = today.toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' });
            const formattedTime = today.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });

            const getStatusBadge = (status) => {
                if (status === "Diterima") {
                    return React.createElement('span', { className: "px-2.5 py-1 bg-emerald-100 text-emerald-700 rounded-full text-[10px] font-bold uppercase tracking-wider flex items-center gap-1.5 inline-flex" },
                        React.createElement(CheckCircle, { size: 12 }), "Diterima"
                    );
                } else if (status === "Ditolak") {
                    return React.createElement('span', { className: "px-2.5 py-1 bg-rose-100 text-rose-700 rounded-full text-[10px] font-bold uppercase tracking-wider flex items-center gap-1.5 inline-flex" },
                        React.createElement(XCircle, { size: 12 }), "Ditolak"
                    );
                } else {
                    return React.createElement('span', { className: "px-2.5 py-1 bg-amber-100 text-amber-700 rounded-full text-[10px] font-bold uppercase tracking-wider flex items-center gap-1.5 inline-flex" },
                        React.createElement(ClockIcon, { size: 12 }), "Direview"
                    );
                }
            };

            return React.createElement('div', { className: "min-h-screen bg-[#f0f4f8]" },
                // Header
                React.createElement('header', { className: "bg-primary text-white px-8 py-8 shadow-lg" },
                    React.createElement('div', { className: "container mx-auto flex flex-col md:flex-row justify-between items-center gap-6" },
                        React.createElement('div', null,
                            React.createElement('h1', { className: "text-3xl font-bold tracking-tight mb-1" }, "Manajemen Booking PKL"),
                            React.createElement('p', { className: "text-slate-300 text-sm opacity-80" }, "Review dan update status pengajuan PKL siswa")
                        ),
                        React.createElement('div', { className: "flex gap-8" },
                            React.createElement('div', { className: "text-center border-r border-white/20 pr-8" },
                                React.createElement('span', { className: "block text-3xl font-bold text-white" }, totalBooking),
                                React.createElement('span', { className: "text-[10px] uppercase tracking-[0.2em] text-slate-300 font-bold" }, "Total Booking")
                            ),
                            React.createElement('div', { className: "text-center border-r border-white/20 pr-8" },
                                React.createElement('span', { className: "block text-3xl font-bold text-amber-400" }, bookingDireview),
                                React.createElement('span', { className: "text-[10px] uppercase tracking-[0.2em] text-slate-300 font-bold" }, "Direview")
                            ),
                            React.createElement('div', { className: "text-center border-r border-white/20 pr-8" },
                                React.createElement('span', { className: "block text-3xl font-bold text-emerald-400" }, bookingDiterima),
                                React.createElement('span', { className: "text-[10px] uppercase tracking-[0.2em] text-slate-300 font-bold" }, "Diterima")
                            ),
                            React.createElement('div', { className: "text-center" },
                                React.createElement('span', { className: "block text-3xl font-bold text-rose-400" }, bookingDitolak),
                                React.createElement('span', { className: "text-[10px] uppercase tracking-[0.2em] text-slate-300 font-bold" }, "Ditolak")
                            )
                        )
                    )
                ),

                // Main Content
                React.createElement('main', { className: "container mx-auto px-4 py-8" },
                    React.createElement('div', { className: "bg-white rounded-2xl shadow-2xl overflow-hidden border border-slate-200" },
                        // Toolbar
                        React.createElement('div', { className: "bg-slate-50 p-6 border-b border-slate-200 flex flex-col md:flex-row justify-between items-center gap-4" },
                            React.createElement('div', { className: "flex flex-col md:flex-row gap-4 w-full md:w-auto" },
                                React.createElement('div', { className: "relative" },
                                    React.createElement('div', { className: "absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none" },
                                        React.createElement(Search, { size: 16, className: "text-slate-400" })
                                    ),
                                    React.createElement('input', { type: "text", placeholder: "Cari nama atau NIS siswa...", className: "pl-10 pr-4 py-2.5 border border-slate-300 rounded-lg text-sm w-full md:w-80 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all bg-white", value: search, onChange: (e) => setSearch(e.target.value) })
                                ),
                                React.createElement('div', { className: "relative" },
                                    React.createElement('div', { className: "absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none" },
                                        React.createElement(Filter, { size: 16, className: "text-slate-400" })
                                    ),
                                    React.createElement('select', { className: "bg-white border border-slate-300 rounded-lg text-sm pl-10 pr-8 py-2.5 outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all appearance-none cursor-pointer w-full", value: statusFilter, onChange: (e) => setStatusFilter(e.target.value) },
                                        React.createElement('option', null, "Semua Status"),
                                        React.createElement('option', null, "Direview"),
                                        React.createElement('option', null, "Diterima"),
                                        React.createElement('option', null, "Ditolak")
                                    )
                                ),
                                React.createElement('div', { className: "relative" },
                                    React.createElement('div', { className: "absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none" },
                                        React.createElement(Clock, { size: 16, className: "text-slate-400" })
                                    ),
                                    React.createElement('select', { className: "bg-white border border-slate-300 rounded-lg text-sm pl-10 pr-8 py-2.5 outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all appearance-none cursor-pointer w-full", value: sortBy, onChange: (e) => setSortBy(e.target.value) },
                                        React.createElement('option', { value: "newest" }, "Terbaru"),
                                        React.createElement('option', { value: "oldest" }, "Terlama"),
                                        React.createElement('option', { value: "siswa_asc" }, "NIS A-Z"),
                                        React.createElement('option', { value: "siswa_desc" }, "NIS Z-A")
                                    )
                                )
                            ),
                            React.createElement('button', { className: "bg-primary hover:bg-[#002542] text-white px-8 py-2.5 rounded-lg text-sm font-bold transition shadow-md flex items-center gap-2 w-full md:w-auto justify-center" },
                                React.createElement(Plus, { size: 18 }), "Tambah Booking"
                            )
                        ),

                        // Table
                        React.createElement('div', { className: "overflow-x-auto" },
                            React.createElement('table', { className: "w-full text-left" },
                                React.createElement('thead', null,
                                    React.createElement('tr', { className: "bg-primary/5 text-primary text-[11px] uppercase font-bold tracking-widest border-b border-slate-200" },
                                        React.createElement('th', { className: "px-6 py-5 w-16 text-center" }, "No"),
                                        React.createElement('th', { className: "px-6 py-5" }, "Nama Siswa"),
                                        React.createElement('th', { className: "px-6 py-5" }, "NIS"),
                                        React.createElement('th', { className: "px-6 py-5" }, "DUDI"),
                                        React.createElement('th', { className: "px-6 py-5 w-32 text-center" }, "Status"),
                                        React.createElement('th', { className: "px-6 py-5 w-32" }, "Tanggal"),
                                        React.createElement('th', { className: "px-6 py-5 text-right w-32" }, "Aksi")
                                    )
                                ),
                                React.createElement('tbody', { className: "divide-y divide-slate-100" },
                                    filteredData.map((booking, idx) => 
                                        React.createElement('tr', { key: booking.id, className: "hover:bg-slate-50/50 transition-colors group" },
                                            React.createElement('td', { className: "px-6 py-4 text-center text-slate-400 font-mono text-xs" }, String(idx + 1).padStart(2, '0')),
                                            React.createElement('td', { className: "px-6 py-4" },
                                                React.createElement('div', { className: "font-bold text-primary text-sm" }, booking.nama_siswa)
                                            ),
                                            React.createElement('td', { className: "px-6 py-4" },
                                                React.createElement('div', { className: "text-slate-500 font-mono text-xs" }, booking.nis)
                                            ),
                                            React.createElement('td', { className: "px-6 py-4" },
                                                React.createElement('div', { className: "text-slate-700 text-sm flex items-center gap-2" },
                                                    React.createElement(Building2, { size: 14, className: "text-slate-400" }), booking.nama_dudi
                                                )
                                            ),
                                            React.createElement('td', { className: "px-6 py-4 text-center" }, getStatusBadge(booking.status)),
                                            React.createElement('td', { className: "px-6 py-4" },
                                                React.createElement('div', { className: "text-slate-500 text-xs" }, booking.tanggal)
                                            ),
                                            React.createElement('td', { className: "px-6 py-4 text-right" },
                                                React.createElement('div', { className: "flex justify-end gap-2" },
                                                    React.createElement('button', { className: "text-primary hover:text-primary/70 p-1.5 hover:bg-primary/5 rounded-lg transition-all", title: "Edit" }, React.createElement(Edit3, { size: 18 })),
                                                    React.createElement('button', { className: "text-red-500 hover:text-red-700 p-1.5 hover:bg-red-50 rounded-lg transition-all", title: "Hapus" }, React.createElement(Trash2, { size: 18 }))
                                                )
                                            )
                                        )
                                    ),
                                    filteredData.length === 0 && 
                                        React.createElement('tr', null,
                                            React.createElement('td', { colSpan: 7, className: "px-6 py-20 text-center text-slate-300" },
                                                React.createElement('div', { className: "flex flex-col items-center gap-3" },
                                                    React.createElement(Search, { size: 48, className: "opacity-10" }),
                                                    React.createElement('p', { className: "font-bold text-xs uppercase tracking-widest" }, "Data Tidak Ditemukan")
                                                )
                                            )
                                        )
                                )
                            )
                        ),

                        // Footer
                        React.createElement('div', { className: "bg-primary text-white/70 px-8 py-5 flex flex-col md:flex-row justify-between items-center gap-4 text-[10px] uppercase font-bold tracking-[0.2em]" },
                            React.createElement('div', { className: "flex items-center gap-3" },
                                React.createElement(Database, { size: 14, className: "text-white/50" }),
                                React.createElement('span', null, "Total data tersimpan: ", React.createElement('span', { className: "text-white font-black" }, totalBooking), " booking")
                            ),
                            React.createElement('div', { className: "flex items-center gap-3" },
                                React.createElement(Clock, { size: 14, className: "text-white/50" }),
                                React.createElement('span', null, "Terakhir diperbarui: ", React.createElement('span', { className: "text-white font-medium" }, formattedDate, ", ", formattedTime))
                            )
                        )
                    ),
                    React.createElement('div', { className: "mt-8 text-center pb-12" },
                        React.createElement('p', { className: "text-slate-400 text-[9px] uppercase tracking-[0.3em] font-black" }, "Sistem Informasi PKL Terpadu © 2026 • Professional Edition")
                    )
                )
            );
        };

        ReactDOM.createRoot(document.getElementById('root')).render(React.createElement(App, null));
    </script>
</body>
</html>