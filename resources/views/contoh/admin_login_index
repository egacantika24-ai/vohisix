<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PKL Master Pro - Manajemen Login</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script crossorigin src="https://unpkg.com/react@18.2.0/umd/react.development.js"></script>
    <script crossorigin src="https://unpkg.com/react-dom@18.2.0/umd/react-dom.development.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Plus Jakarta Sans', ui-sans-serif, system-ui, sans-serif; background-color: #f0f4f8; }
        .bg-primary { background-color: #003056; }
        .text-primary { color: #003056; }
        .border-primary { border-color: #003056; }
        .ring-primary { ring-color: #003056; }
        .from-primary { --tw-gradient-from: #003056; }
        .to-primary { --tw-gradient-to: #003056; }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #F1F5F9; border-radius: 10px; }
        ::-webkit-scrollbar-thumb { background: #003056; border-radius: 10px; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        @keyframes scaleIn { from { opacity: 0; scale: 0.95; } to { opacity: 1; scale: 1; } }
    </style>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useMemo } = React;

        // Icons
        const Users = ({ size = 20 }) => React.createElement('svg', { width: size, height: size, viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', strokeWidth: 2, strokeLinecap: 'round', strokeLinejoin: 'round' },
            React.createElement('path', { d: 'M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2' }),
            React.createElement('circle', { cx: 9, cy: 7, r: 4 }),
            React.createElement('path', { d: 'M23 21v-2a4 4 0 0 0-3-3.87' }),
            React.createElement('path', { d: 'M16 3.13a4 4 0 0 1 0 7.75' })
        );
        const UserCheck = ({ size = 20 }) => React.createElement('svg', { width: size, height: size, viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', strokeWidth: 2, strokeLinecap: 'round', strokeLinejoin: 'round' },
            React.createElement('path', { d: 'M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2' }),
            React.createElement('circle', { cx: 9, cy: 7, r: 4 }),
            React.createElement('polyline', { points: '16 11 18 13 22 9' })
        );
        const UserMinus = ({ size = 20 }) => React.createElement('svg', { width: size, height: size, viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', strokeWidth: 2, strokeLinecap: 'round', strokeLinejoin: 'round' },
            React.createElement('path', { d: 'M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2' }),
            React.createElement('circle', { cx: 9, cy: 7, r: 4 }),
            React.createElement('line', { x1: 22, y1: 11, x2: 18, y2: 11 })
        );
        const Search = ({ size = 16 }) => React.createElement('svg', { width: size, height: size, viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', strokeWidth: 2, strokeLinecap: 'round', strokeLinejoin: 'round' },
            React.createElement('circle', { cx: 11, cy: 11, r: 8 }),
            React.createElement('line', { x1: 21, y1: 21, x2: 16.65, y2: 16.65 })
        );
        const Plus = ({ size = 18 }) => React.createElement('svg', { width: size, height: size, viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', strokeWidth: 2, strokeLinecap: 'round', strokeLinejoin: 'round' },
            React.createElement('line', { x1: 12, y1: 5, x2: 12, y2: 19 }),
            React.createElement('line', { x1: 5, y1: 12, x2: 19, y2: 12 })
        );
        const Trash2 = ({ size = 18 }) => React.createElement('svg', { width: size, height: size, viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', strokeWidth: 2, strokeLinecap: 'round', strokeLinejoin: 'round' },
            React.createElement('path', { d: 'M3 6h18' }),
            React.createElement('path', { d: 'M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2' })
        );
        const Edit3 = ({ size = 18 }) => React.createElement('svg', { width: size, height: size, viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', strokeWidth: 2, strokeLinecap: 'round', strokeLinejoin: 'round' },
            React.createElement('path', { d: 'M17 3l4 4L7 21H3v-4L17 3z' })
        );
        const Filter = ({ size = 16 }) => React.createElement('svg', { width: size, height: size, viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', strokeWidth: 2, strokeLinecap: 'round', strokeLinejoin: 'round' },
            React.createElement('polygon', { points: '22 3 2 3 10 13 10 21 14 18 14 13 22 3' })
        );
        const Database = ({ size = 16 }) => React.createElement('svg', { width: size, height: size, viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', strokeWidth: 2, strokeLinecap: 'round', strokeLinejoin: 'round' },
            React.createElement('ellipse', { cx: 12, cy: 5, rx: 9, ry: 3 }),
            React.createElement('path', { d: 'M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5' }),
            React.createElement('path', { d: 'M3 12c0 1.66 4 3 9 3s9-1.34 9-3' })
        );
        const Clock = ({ size = 16 }) => React.createElement('svg', { width: size, height: size, viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', strokeWidth: 2, strokeLinecap: 'round', strokeLinejoin: 'round' },
            React.createElement('circle', { cx: 12, cy: 12, r: 10 }),
            React.createElement('polyline', { points: '12 6 12 12 16 14' })
        );
        const Shield = ({ size = 20 }) => React.createElement('svg', { width: size, height: size, viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', strokeWidth: 2, strokeLinecap: 'round', strokeLinejoin: 'round' },
            React.createElement('path', { d: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z' })
        );

        // Mock Data Users
        const MOCK_USERS = [
            { id: 1, username: "admin_pkl", name: "Administrator PKL", role: "admin", created_at: "2024-01-15" },
            { id: 2, username: "ahmad_fauzi", name: "Ahmad Fauzi", role: "siswa", created_at: "2024-01-20" },
            { id: 3, username: "siti_nur", name: "Siti Nurhaliza", role: "siswa", created_at: "2024-02-10" },
            { id: 4, username: "budi_santoso", name: "Budi Santoso", role: "siswa", created_at: "2024-02-15" },
            { id: 5, username: "diana_putri", name: "Diana Putri", role: "siswa", created_at: "2024-03-05" },
            { id: 6, username: "eko_prasetyo", name: "Eko Prasetyo", role: "siswa", created_at: "2024-03-12" },
            { id: 7, username: "rina_wati", name: "Rina Wati", role: "siswa", created_at: "2024-03-20" }
        ];

        const App = () => {
            const [search, setSearch] = useState("");
            const [roleFilter, setRoleFilter] = useState("Semua Role");
            const [sortBy, setSortBy] = useState("newest");

            const filteredData = useMemo(() => {
                let data = MOCK_USERS.filter(user => {
                    const matchesSearch = user.name.toLowerCase().includes(search.toLowerCase()) || 
                                         user.username.toLowerCase().includes(search.toLowerCase());
                    const matchesRole = roleFilter === "Semua Role" || user.role === roleFilter.toLowerCase();
                    return matchesSearch && matchesRole;
                });

                // Sorting
                data = [...data].sort((a, b) => {
                    if (sortBy === "newest") return new Date(b.created_at) - new Date(a.created_at);
                    if (sortBy === "oldest") return new Date(a.created_at) - new Date(b.created_at);
                    if (sortBy === "name_asc") return a.name.localeCompare(b.name);
                    if (sortBy === "name_desc") return b.name.localeCompare(a.name);
                    return 0;
                });

                return data;
            }, [search, roleFilter, sortBy]);

            const totalUser = MOCK_USERS.length;
            const totalAdmin = MOCK_USERS.filter(u => u.role === "admin").length;
            const totalSiswa = MOCK_USERS.filter(u => u.role === "siswa").length;

            // Format tanggal saat ini
            const today = new Date();
            const formattedDate = today.toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' });
            const formattedTime = today.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });

            return React.createElement('div', { className: "min-h-screen bg-[#f0f4f8]" },
                // Header
                React.createElement('header', { className: "bg-primary text-white px-8 py-8 shadow-lg" },
                    React.createElement('div', { className: "container mx-auto flex flex-col md:flex-row justify-between items-center gap-6" },
                        React.createElement('div', null,
                            React.createElement('h1', { className: "text-3xl font-bold tracking-tight mb-1" }, "Manajemen Login"),
                            React.createElement('p', { className: "text-slate-300 text-sm opacity-80" }, "Kelola akun user (Admin & Siswa) untuk akses sistem PKL")
                        ),
                        React.createElement('div', { className: "flex gap-8" },
                            React.createElement('div', { className: "text-center border-r border-white/20 pr-8" },
                                React.createElement('span', { className: "block text-3xl font-bold text-white" }, totalUser),
                                React.createElement('span', { className: "text-[10px] uppercase tracking-[0.2em] text-slate-300 font-bold" }, "Total User")
                            ),
                            React.createElement('div', { className: "text-center border-r border-white/20 pr-8" },
                                React.createElement('span', { className: "block text-3xl font-bold text-white" }, totalAdmin),
                                React.createElement('span', { className: "text-[10px] uppercase tracking-[0.2em] text-slate-300 font-bold" }, "Admin")
                            ),
                            React.createElement('div', { className: "text-center" },
                                React.createElement('span', { className: "block text-3xl font-bold text-white" }, totalSiswa),
                                React.createElement('span', { className: "text-[10px] uppercase tracking-[0.2em] text-slate-300 font-bold" }, "Siswa")
                            )
                        )
                    )
                ),

                // Main Content
                React.createElement('main', { className: "container mx-auto px-4 py-8" },
                    React.createElement('div', { className: "bg-white rounded-2xl shadow-2xl overflow-hidden border border-slate-200" },
                        // Toolbar
                        React.createElement('div', { className: "bg-slate-50 p-6 border-b border-slate-200 flex flex-col md:flex-row justify-between items-center gap-4" },
                            React.createElement('div', { className: "flex flex-col md:flex-row gap-4 w-full md:w-auto" },
                                React.createElement('div', { className: "relative" },
                                    React.createElement('div', { className: "absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none" },
                                        React.createElement(Search, { size: 16, className: "text-slate-400" })
                                    ),
                                    React.createElement('input', { type: "text", placeholder: "Cari username atau nama...", className: "pl-10 pr-4 py-2.5 border border-slate-300 rounded-lg text-sm w-full md:w-80 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all bg-white", value: search, onChange: (e) => setSearch(e.target.value) })
                                ),
                                React.createElement('div', { className: "relative" },
                                    React.createElement('div', { className: "absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none" },
                                        React.createElement(Filter, { size: 16, className: "text-slate-400" })
                                    ),
                                    React.createElement('select', { className: "bg-white border border-slate-300 rounded-lg text-sm pl-10 pr-8 py-2.5 outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all appearance-none cursor-pointer w-full", value: roleFilter, onChange: (e) => setRoleFilter(e.target.value) },
                                        React.createElement('option', null, "Semua Role"),
                                        React.createElement('option', null, "Admin"),
                                        React.createElement('option', null, "Siswa")
                                    )
                                ),
                                React.createElement('div', { className: "relative" },
                                    React.createElement('div', { className: "absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none" },
                                        React.createElement(Shield, { size: 16, className: "text-slate-400" })
                                    ),
                                    React.createElement('select', { className: "bg-white border border-slate-300 rounded-lg text-sm pl-10 pr-8 py-2.5 outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all appearance-none cursor-pointer w-full", value: sortBy, onChange: (e) => setSortBy(e.target.value) },
                                        React.createElement('option', { value: "newest" }, "Terbaru"),
                                        React.createElement('option', { value: "oldest" }, "Terlama"),
                                        React.createElement('option', { value: "name_asc" }, "Nama A-Z"),
                                        React.createElement('option', { value: "name_desc" }, "Nama Z-A")
                                    )
                                )
                            ),
                            React.createElement('button', { className: "bg-primary hover:bg-[#002542] text-white px-8 py-2.5 rounded-lg text-sm font-bold transition shadow-md flex items-center gap-2 w-full md:w-auto justify-center" },
                                React.createElement(Plus, { size: 18 }), "Tambah User Baru"
                            )
                        ),

                        // Table
                        React.createElement('div', { className: "overflow-x-auto" },
                            React.createElement('table', { className: "w-full text-left" },
                                React.createElement('thead', null,
                                    React.createElement('tr', { className: "bg-primary/5 text-primary text-[11px] uppercase font-bold tracking-widest border-b border-slate-200" },
                                        React.createElement('th', { className: "px-6 py-5 w-16 text-center" }, "No"),
                                        React.createElement('th', { className: "px-6 py-5" }, "Username"),
                                        React.createElement('th', { className: "px-6 py-5" }, "Nama Lengkap"),
                                        React.createElement('th', { className: "px-6 py-5 w-32 text-center" }, "Role"),
                                        React.createElement('th', { className: "px-6 py-5 text-right w-32" }, "Aksi")
                                    )
                                ),
                                React.createElement('tbody', { className: "divide-y divide-slate-100" },
                                    filteredData.map((user, idx) => 
                                        React.createElement('tr', { key: user.id, className: "hover:bg-slate-50/50 transition-colors group" },
                                            React.createElement('td', { className: "px-6 py-4 text-center text-slate-400 font-mono text-xs" }, String(idx + 1).padStart(2, '0')),
                                            React.createElement('td', { className: "px-6 py-4" },
                                                React.createElement('div', { className: "font-bold text-primary text-sm" }, user.username)
                                            ),
                                            React.createElement('td', { className: "px-6 py-4" },
                                                React.createElement('div', { className: "text-slate-700 text-sm" }, user.name)
                                            ),
                                            React.createElement('td', { className: "px-6 py-4 text-center" },
                                                user.role === 'admin' 
                                                    ? React.createElement('span', { className: "px-3 py-1 bg-purple-100 text-purple-700 rounded-full text-[10px] font-bold uppercase tracking-wider" }, "Admin")
                                                    : React.createElement('span', { className: "px-3 py-1 bg-blue-100 text-blue-700 rounded-full text-[10px] font-bold uppercase tracking-wider" }, "Siswa")
                                            ),
                                            React.createElement('td', { className: "px-6 py-4 text-right" },
                                                React.createElement('div', { className: "flex justify-end gap-1" },
                                                    React.createElement('button', { className: "text-primary hover:text-primary/70 p-1.5 hover:bg-primary/5 rounded-lg transition-all", title: "Edit" }, React.createElement(Edit3, { size: 18 })),
                                                    React.createElement('button', { className: "text-red-500 hover:text-red-700 p-1.5 hover:bg-red-50 rounded-lg transition-all", title: "Hapus" }, React.createElement(Trash2, { size: 18 }))
                                                )
                                            )
                                        )
                                    ),
                                    filteredData.length === 0 && 
                                        React.createElement('tr', null,
                                            React.createElement('td', { colSpan: 5, className: "px-6 py-20 text-center text-slate-300" },
                                                React.createElement('div', { className: "flex flex-col items-center gap-3" },
                                                    React.createElement(Search, { size: 48, className: "opacity-10" }),
                                                    React.createElement('p', { className: "font-bold text-xs uppercase tracking-widest" }, "Data Tidak Ditemukan")
                                                )
                                            )
                                        )
                                )
                            )
                        ),

                        // Footer
                        React.createElement('div', { className: "bg-primary text-white/70 px-8 py-5 flex flex-col md:flex-row justify-between items-center gap-4 text-[10px] uppercase font-bold tracking-[0.2em]" },
                            React.createElement('div', { className: "flex items-center gap-3" },
                                React.createElement(Database, { size: 14, className: "text-white/50" }),
                                React.createElement('span', null, "Total user terdaftar: ", React.createElement('span', { className: "text-white font-black" }, totalUser), " akun")
                            ),
                            React.createElement('div', { className: "flex items-center gap-3" },
                                React.createElement(Clock, { size: 14, className: "text-white/50" }),
                                React.createElement('span', null, "Terakhir diperbarui: ", React.createElement('span', { className: "text-white font-medium" }, formattedDate, ", ", formattedTime))
                            )
                        )
                    ),
                    React.createElement('div', { className: "mt-8 text-center pb-12" },
                        React.createElement('p', { className: "text-slate-400 text-[9px] uppercase tracking-[0.3em] font-black" }, "Sistem Informasi PKL Terpadu © 2026 • Professional Edition")
                    )
                )
            );
        };

        ReactDOM.createRoot(document.getElementById('root')).render(React.createElement(App, null));
    </script>
</body>
</html>