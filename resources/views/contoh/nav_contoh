<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Portal PKL - Sidebar Navigation</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script crossorigin src="https://unpkg.com/react@18.2.0/umd/react.development.js"></script>
    <script crossorigin src="https://unpkg.com/react-dom@18.2.0/umd/react-dom.development.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;500;600;700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Outfit', ui-sans-serif, system-ui, sans-serif;
            background: linear-gradient(135deg, #e8f0fe 0%, #f0f4fa 100%);
        }
        
        .font-display {
            font-family: 'Quicksand', sans-serif;
        }
        
        .sidebar {
            width: 320px;
        }
        
        ::-webkit-scrollbar {
            width: 6px;
        }
        
        ::-webkit-scrollbar-track {
            background: #E2E8F0;
            border-radius: 10px;
        }
        
        ::-webkit-scrollbar-thumb {
            background: #003056;
            border-radius: 10px;
        }
        
        .clickable-avatar {
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        .clickable-avatar:hover {
            transform: scale(1.05);
            box-shadow: 0 8px 20px rgba(0, 48, 86, 0.15);
        }
        
        .profile-card {
            background: linear-gradient(135deg, #003056 0%, #00457d 100%);
        }
    </style>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState } = React;

        // Mock Data
        const STUDENT_DATA = {
            nama: "Ahmad Fauzi",
            nis: "212210123",
            kelas: "XII RPL 2",
            program: "Rekayasa Perangkat Lunak",
        };

        // Icon components
        const LayoutDashboard = () => <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>;
        const FileText = () => <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>;
        const User = () => <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>;
        const Settings = () => <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>;
        const LogOut = () => <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>;

        function NavItem({ icon, label, active = false }) {
            return (
                <a href="#" className={`flex items-center gap-3 px-6 py-4 rounded-2xl text-sm transition-all shadow-sm border ${
                    active 
                        ? 'bg-white text-[#003056] font-bold border-white/60 shadow-md' 
                        : 'text-slate-500 hover:bg-white/30 hover:text-[#003056] font-semibold border-transparent'
                }`}>
                    <span className={`${active ? 'text-[#003056]' : 'text-slate-400 group-hover:text-[#003056]'}`}>{icon}</span>
                    <span>{label}</span>
                </a>
            );
        }

        function App() {
            const handleAvatarClick = () => {
                alert("Profil siswa: " + STUDENT_DATA.nama + "\nNIS: " + STUDENT_DATA.nis + "\nKelas: " + STUDENT_DATA.kelas);
            };

            const handleLogout = () => {
                alert("Anda telah keluar dari sistem");
            };

            return (
                <div className="min-h-screen flex items-center justify-center" style={{ background: 'linear-gradient(135deg, #e8f0fe 0%, #f0f4fa 100%)' }}>
                    {/* Sidebar Only */}
                    <aside className="sidebar fixed h-full bg-white flex flex-col border-r border-slate-200 shadow-xl z-10">
                        <div className="p-8">
                            {/* Profile Card - Langsung di atas, tanpa logo */}
                            <div className="mb-8">
                                <div className="profile-card p-6 rounded-2xl shadow-lg">
                                    {/* Avatar Clickable */}
                                    <div className="w-16 h-16 bg-white rounded-full mx-auto mb-3 border-4 border-white/30 shadow-inner overflow-hidden clickable-avatar" onClick={handleAvatarClick}>
                                        <img 
                                            src={`https://api.dicebear.com/7.x/avataaars/svg?seed=${STUDENT_DATA.nama}`} 
                                            alt="Avatar"
                                            className="w-full h-full object-cover"
                                        />
                                    </div>
                                    <h2 className="text-center font-bold text-white text-lg font-display">{STUDENT_DATA.nama}</h2>
                                    <p className="text-center text-xs text-blue-200 tracking-wider font-semibold">NIS: {STUDENT_DATA.nis}</p>
                                    <div className="mt-4 flex justify-center">
                                        <span className="px-3 py-1 bg-white/20 text-white rounded-full text-[10px] font-bold uppercase tracking-tighter shadow-sm border border-white/30">{STUDENT_DATA.kelas}</span>
                                    </div>
                                </div>
                            </div>

                            {/* Navigation Menu */}
                            <nav className="space-y-2">
                                <NavItem icon={<LayoutDashboard />} label="Dashboard" active />
                                <NavItem icon={<FileText />} label="Berkas Saya" />
                                <NavItem icon={<User />} label="Profil" />
                                <NavItem icon={<Settings />} label="Pengaturan" />
                            </nav>
                        </div>
                        
                        {/* Logout Button - Rata Kiri, sejajar dengan menu */}
                        <div className="mt-auto p-8 border-t border-slate-200/50">
                            <button 
                                onClick={handleLogout}
                                className="flex items-center gap-3 text-red-600 hover:text-red-700 hover:bg-red-50 transition-colors font-semibold text-sm py-3 px-6 rounded-xl w-full"
                            >
                                <LogOut />
                                <span>Keluar Akun</span>
                            </button>
                        </div>
                    </aside>
                </div>
            );
        }

        ReactDOM.createRoot(document.getElementById('root')).render(<React.StrictMode><App /></React.StrictMode>);
    </script>
</body>
</html>