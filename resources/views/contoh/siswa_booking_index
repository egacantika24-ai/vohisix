<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Portal PKL - Status Center</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script crossorigin src="https://unpkg.com/react@18.2.0/umd/react.development.js"></script>
    <script crossorigin src="https://unpkg.com/react-dom@18.2.0/umd/react-dom.development.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', ui-sans-serif, system-ui, sans-serif; background-color: #F8FAFC; }
        .bg-primary { background-color: #003056; }
        .text-primary { color: #003056; }
        .border-primary { border-color: #003056; }
        .shadow-primary\/20 { box-shadow: 0 10px 25px -5px rgba(0, 48, 86, 0.2); }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #F1F5F9; border-radius: 10px; }
        ::-webkit-scrollbar-thumb { background: #CBD5E1; border-radius: 10px; }
        @keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect } = React;

        // Icons
        const Building2 = ({ size = 20 }) => React.createElement('svg', { width: size, height: size, viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', strokeWidth: 2, strokeLinecap: 'round', strokeLinejoin: 'round' },
            React.createElement('rect', { x: 4, y: 2, width: 16, height: 20, rx: 2, ry: 2 }),
            React.createElement('path', { d: 'M9 22v-4h6v4' })
        );
        const CheckCircle2 = ({ size = 20 }) => React.createElement('svg', { width: size, height: size, viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', strokeWidth: 2, strokeLinecap: 'round', strokeLinejoin: 'round' },
            React.createElement('circle', { cx: 12, cy: 12, r: 10 }),
            React.createElement('polyline', { points: '9 12 11 14 15 10' })
        );
        const Clock = ({ size = 12 }) => React.createElement('svg', { width: size, height: size, viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', strokeWidth: 2, strokeLinecap: 'round', strokeLinejoin: 'round' },
            React.createElement('circle', { cx: 12, cy: 12, r: 10 }),
            React.createElement('polyline', { points: '12 6 12 12 16 14' })
        );
        const Search = ({ size = 16 }) => React.createElement('svg', { width: size, height: size, viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', strokeWidth: 2, strokeLinecap: 'round', strokeLinejoin: 'round' },
            React.createElement('circle', { cx: 11, cy: 11, r: 8 }),
            React.createElement('line', { x1: 21, y1: 21, x2: 16.65, y2: 16.65 })
        );
        const XCircle = ({ size = 20 }) => React.createElement('svg', { width: size, height: size, viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', strokeWidth: 2, strokeLinecap: 'round', strokeLinejoin: 'round' },
            React.createElement('circle', { cx: 12, cy: 12, r: 10 }),
            React.createElement('line', { x1: 15, y1: 9, x2: 9, y2: 15 }),
            React.createElement('line', { x1: 9, y1: 9, x2: 15, y2: 15 })
        );
        const ArrowRight = ({ size = 20 }) => React.createElement('svg', { width: size, height: size, viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', strokeWidth: 2, strokeLinecap: 'round', strokeLinejoin: 'round' },
            React.createElement('line', { x1: 5, y1: 12, x2: 19, y2: 12 }),
            React.createElement('polyline', { points: '12 5 19 12 12 19' })
        );
        const FileText = ({ size = 20 }) => React.createElement('svg', { width: size, height: size, viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', strokeWidth: 2, strokeLinecap: 'round', strokeLinejoin: 'round' },
            React.createElement('path', { d: 'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z' }),
            React.createElement('polyline', { points: '14 2 14 8 20 8' })
        );

        const MOCK_BOOKINGS = [
            { id: '1', dudi: { nama_dudi: 'PT Teknologi Digital Indonesia', bidang_usaha: 'Software Engineering' }, status: 'Diterima', created_at: '15 Apr 2026' },
            { id: '2', dudi: { nama_dudi: 'Bank Central Nasional', bidang_usaha: 'Financial Services' }, status: 'Ditolak', created_at: '18 Apr 2026' },
            { id: '3', dudi: { nama_dudi: 'Startup Kreatif Nusantara', bidang_usaha: 'Creative Agency' }, status: 'Direview', created_at: '20 Apr 2026' },
            { id: '4', dudi: { nama_dudi: 'Global Logistik Perkasa', bidang_usaha: 'Supply Chain' }, status: 'Direview', created_at: '21 Apr 2026' }
        ];

        const App = () => {
            const [bookings] = useState(MOCK_BOOKINGS);
            const [activeTab, setActiveTab] = useState('All');

            const stats = {
                total: bookings.length,
                accepted: bookings.filter(b => b.status === 'Diterima').length,
                rejected: bookings.filter(b => b.status === 'Ditolak').length
            };

            const filteredBookings = activeTab === 'All' ? bookings : bookings.filter(b => b.status === activeTab);

            const getStatusMeta = (status) => {
                if (status === 'Diterima') return { color: 'text-emerald-500', bg: 'bg-emerald-500/10', label: 'Accepted' };
                if (status === 'Ditolak') return { color: 'text-rose-500', bg: 'bg-rose-500/10', label: 'Declined' };
                return { color: 'text-amber-500', bg: 'bg-amber-500/10', label: 'Reviewing' };
            };

            return React.createElement('div', { className: "min-h-screen bg-[#F8FAFC]" },
                // Header
                React.createElement('nav', { className: "sticky top-0 z-50 bg-white/80 backdrop-blur-xl border-b border-slate-200" },
                    React.createElement('div', { className: "max-w-5xl mx-auto px-6 h-16 flex items-center justify-between" },
                        React.createElement('div', { className: "flex items-center gap-2.5" },
                            React.createElement('div', { className: "w-9 h-9 bg-primary rounded-xl flex items-center justify-center text-white shadow-md" },
                                React.createElement(Building2, { size: 18 })
                            ),
                            React.createElement('div', null,
                                React.createElement('span', { className: "text-lg font-black tracking-tight text-primary" }, "PortalPKL"),
                                React.createElement('span', { className: "text-[8px] font-bold text-slate-400 uppercase tracking-wider block leading-3" }, "Status Center")
                            )
                        ),
                        React.createElement('div', { className: "flex items-center gap-3" },
                            React.createElement('div', { className: "w-8 h-8 rounded-full bg-gradient-to-br from-primary to-blue-400 p-0.5" },
                                React.createElement('div', { className: "w-full h-full rounded-full bg-white flex items-center justify-center" },
                                    React.createElement('span', { className: "text-[10px] font-black text-primary" }, "AW")
                                )
                            )
                        )
                    )
                ),

                // Main Content
                React.createElement('main', { className: "max-w-5xl mx-auto px-6 py-12" },
                    // Header Section
                    React.createElement('div', { className: "mb-12 text-center md:text-left" },
                        React.createElement('h1', { className: "text-4xl md:text-6xl font-black tracking-tight text-primary leading-[1.1] mb-4" },
                            "Your PKL ", React.createElement('span', { className: "text-transparent bg-clip-text bg-gradient-to-r from-primary to-blue-500" }, "Journey")
                        ),
                        React.createElement('p', { className: "text-slate-500 max-w-lg text-base font-medium" },
                            "Monitor your internship applications with ease."
                        )
                    ),

                    // Stats Cards
                    React.createElement('div', { className: "grid grid-cols-3 gap-4 mb-12" },
                        // Total Card
                        React.createElement('div', { className: "bg-primary p-5 rounded-2xl text-white" },
                            React.createElement(FileText, { size: 20 }),
                            React.createElement('p', { className: "text-[10px] font-black uppercase tracking-wider mt-3 opacity-80" }, "Applications"),
                            React.createElement('p', { className: "text-3xl font-black mt-1" }, stats.total)
                        ),
                        // Accepted Card
                        React.createElement('div', { className: "bg-emerald-500 p-5 rounded-2xl text-white" },
                            React.createElement(CheckCircle2, { size: 20 }),
                            React.createElement('p', { className: "text-[10px] font-black uppercase tracking-wider mt-3 opacity-80" }, "Accepted"),
                            React.createElement('p', { className: "text-3xl font-black mt-1" }, stats.accepted)
                        ),
                        // Declined Card
                        React.createElement('div', { className: "bg-white border border-slate-200 p-5 rounded-2xl text-primary" },
                            React.createElement(XCircle, { size: 20 }),
                            React.createElement('p', { className: "text-[10px] font-black uppercase tracking-wider mt-3 text-slate-400" }, "Declined"),
                            React.createElement('p', { className: "text-3xl font-black mt-1" }, stats.rejected)
                        )
                    ),

                    // Tabs
                    React.createElement('div', { className: "flex items-center justify-between mb-6" },
                        React.createElement('h2', { className: "text-xl font-black text-primary" }, "History"),
                        React.createElement('div', { className: "flex gap-1 bg-slate-100 p-1 rounded-xl" },
                            ['All', 'Diterima', 'Ditolak', 'Direview'].map(tab => 
                                React.createElement('button', {
                                    key: tab,
                                    onClick: () => setActiveTab(tab),
                                    className: `px-4 py-1.5 text-[10px] font-black uppercase tracking-wider rounded-lg transition-all ${activeTab === tab ? 'bg-primary text-white shadow-sm' : 'text-slate-500'}`
                                }, tab)
                            )
                        )
                    ),

                    // List
                    React.createElement('div', { className: "space-y-3" },
                        filteredBookings.length > 0 ? filteredBookings.map((booking, idx) => {
                            const meta = getStatusMeta(booking.status);
                            return React.createElement('div', { 
                                key: booking.id,
                                className: "bg-white border border-slate-200 rounded-2xl p-5 hover:shadow-md transition-all",
                                style: { animation: `fadeInUp 0.3s ease-out ${idx * 0.05}s both` }
                            },
                                React.createElement('div', { className: "flex items-center justify-between flex-wrap gap-4" },
                                    React.createElement('div', { className: "flex items-center gap-4" },
                                        React.createElement('div', { className: "w-12 h-12 bg-slate-50 rounded-xl flex items-center justify-center text-primary" },
                                            React.createElement(Building2, { size: 24 })
                                        ),
                                        React.createElement('div', null,
                                            React.createElement('h3', { className: "font-bold text-primary text-sm" }, booking.dudi.nama_dudi),
                                            React.createElement('p', { className: "text-[10px] text-slate-400 mt-0.5" }, booking.dudi.bidang_usaha)
                                        )
                                    ),
                                    React.createElement('div', { className: "flex items-center gap-4" },
                                        React.createElement('div', { className: `px-3 py-1 rounded-full ${meta.bg} ${meta.color} text-[9px] font-black uppercase tracking-wider` }, meta.label),
                                        React.createElement('span', { className: "flex items-center gap-1 text-[10px] text-slate-400" },
                                            React.createElement(Clock, { size: 10 }), " ", booking.created_at
                                        ),
                                        React.createElement('button', { className: "w-10 h-10 rounded-xl bg-slate-50 text-primary flex items-center justify-center hover:bg-primary hover:text-white transition-all" },
                                            React.createElement(ArrowRight, { size: 16 })
                                        )
                                    )
                                )
                            );
                        }) : React.createElement('div', { className: "text-center py-16 bg-white border-2 border-dashed border-slate-200 rounded-3xl" },
                            React.createElement('p', { className: "text-slate-400 font-medium text-sm" }, "No applications found")
                        )
                    )
                ),

                // Footer
                React.createElement('footer', { className: "py-8 border-t border-slate-200 text-center mt-8" },
                    React.createElement('p', { className: "text-[9px] font-bold text-slate-400 uppercase tracking-[0.2em]" }, "PortalPKL • 2026")
                )
            );
        };

        ReactDOM.createRoot(document.getElementById('root')).render(React.createElement(App, null));
    </script>
</body>
</html>